<launch>

    <let name="robot_urdf_path" value="$(find-pkg-share my_agent_description)/urdf/robot/my_robot.urdf.xacro" />
    <let name="sdf_path" value="$(find-pkg-share my_agent_bringup)/world/monza.sdf" />
    <let name="gazebo_config_path" value="$(find-pkg-share my_agent_bringup)/config/gazebo_bridge.yaml" />
    <let name="gazebo_gui_config_path" value="$(find-pkg-share my_agent_bringup)/config/keypublisher.config" />

    <set_env name="GZ_SIM_RESOURCE_PATH" value="$(env GZ_SIM_RESOURCE_PATH):$(find-pkg-share my_agent_bringup)/world"/>

    <!-- Starts up Gazebo using the specified world .sdf file -->
    <include
        file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var sdf_path) -r --gui-config $(var gazebo_gui_config_path)" /> 
        <!-- loads in the .sdf file and then uses the -r tag to immediately run DartSim -->
    </include>

    <!-- Starts up the core robot state publisher node which requires the robot urdf as a paremeter -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher"> 
        <param name="robot_description" value="$(command 'xacro $(var robot_urdf_path)')" />
    </node>

    <!-- Robot spawning. Grabs the urdf from robot_description topic that RSP publishes to -->
    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

    <!-- Initializes the ros to gz bridge. It takes in the .yaml bridge we made and turns gz topics into ros topics -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">  
        <param name="config_file"  value="$(var gazebo_config_path)" /> 
    </node>

</launch>